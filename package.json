  "version": "0.1.0",
  "description": "AI-Powered IT Support Desktop Application",
  "author": "Jules",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
